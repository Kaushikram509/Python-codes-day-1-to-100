#sparate the even and odd values
s=list(map(int,input().split()))
even=[]
odd=[]
for i in s:
    if i%2==0:
        even.append(i)
    else:
        odd.append(i)
print(even)
print(odd)


#find the minumum value
li = list(map(int,input().split()))
min_val=li[0]
for i in range(1,len(li)):
    if min_val>li[i]:
        min_val=li[i]
print(min_val)


#find the maxminum value
li = list(map(int,input().split()))
max_val=li[0]
for i in range(1,len(li)):
    if max_val<li[i]:
        max_val=li[i]
print(max_val)




